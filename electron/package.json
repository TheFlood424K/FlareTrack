{
  "name": "flaretrack",
  "version": "1.0.0",
  "description": "FlareTrack - Chronic Illness Tracker with AI Flare-Up Prediction",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": ["health", "tracker", "chronic-illness", "flare-up"],
  "author": "TheFlood424K",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "chart.js": "^4.4.0"
  },
  "build": {
    "appId": "com.flaretrack.app",
    "productName": "FlareTrack",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
